<Window x:Class="WpfnetfrFiledApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfnetfrFiledApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        Closing="Window_Closing"
        >
    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="LightGray">
            <!--文件菜单-->
            <MenuItem Header="_文件">
                <MenuItem Header="_新建" x:Name="NewAction" InputGestureText="Ctrl+N" Click="NewAction_Click"/>
                <MenuItem Header="_打开" x:Name="OpenAction" Click="OpenAction_Click"  InputGestureText="Ctrl+O" />
                <Separator />
                <!-- 分隔线 -->
                <MenuItem Header="退出" x:Name="ExitAction" Click="ExitAction_Click"/>
            </MenuItem>
            <!-- 3. 一级菜单：编辑，包含子菜单 -->
            <MenuItem Header="_编辑">
                <MenuItem Header="剪切" />
                <MenuItem Header="复制" />
                <MenuItem Header="粘贴" />
            </MenuItem>
        </Menu>
        <Grid>
            <TextBox  x:Name="TextBox1" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
        </Grid>
    </DockPanel>
</Window>
